{
  "expo": {
    "name": "FOCO",
    "slug": "foco",
    "version": "0.2.0",
    "orientation": "portrait",
    "scheme": "foco",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#050607",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.jbskoodcyber.foco",
      "supportsTablet": false
    },
    "android": {
      "package": "com.jbskoodcyber.foco",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": true
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#050607",
          "imageWidth": 120,
          "dark": {
            "backgroundColor": "#050607"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
