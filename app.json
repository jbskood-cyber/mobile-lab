{
  "expo": {
    "name": "FOCO",
    "slug": "foco",
    "version": "0.4.0",
    "orientation": "portrait",
    "scheme": "foco",
    "userInterfaceStyle": "automatic",
    "backgroundColor": "#F6F7F9",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.jbskoodcyber.foco",
      "supportsTablet": false,
      "userInterfaceStyle": "automatic"
    },
    "android": {
      "package": "com.jbskoodcyber.foco",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": true,
      "userInterfaceStyle": "automatic"
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#F6F7F9",
          "dark": {
            "backgroundColor": "#08090B"
          }
        }
      ],
      [
        "expo-navigation-bar",
        {
          "backgroundColor": "#08090B",
          "barStyle": "light",
          "borderColor": "#08090B",
          "position": "absolute"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
