{
  "expo": {
    "name": "FOCO",
    "slug": "foco",
    "version": "0.3.0",
    "orientation": "portrait",
    "scheme": "foco",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#050607",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.jbskoodcyber.foco",
      "supportsTablet": false
    },
    "android": {
      "package": "com.jbskoodcyber.foco",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": true
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#050607"
        }
      ],
      [
        "expo-navigation-bar",
        {
          "backgroundColor": "#050607",
          "barStyle": "light",
          "borderColor": "#050607",
          "position": "absolute"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
