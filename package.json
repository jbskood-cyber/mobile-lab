{
  "name": "foco",
  "main": "expo-router/entry",
  "version": "0.4.0",
  "private": true,
  "scripts": {
    "start": "expo start",
    "start:lan": "expo start --lan",
    "start:dev": "expo start --dev-client --lan",
    "start:tunnel": "expo start --tunnel",
    "android": "expo start --android",
    "android:dev": "expo run:android --device",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "node -e \"require('fs').rmSync('.test-dist',{recursive:true,force:true});require('fs').rmSync('.core-test-dist',{recursive:true,force:true})\" && tsc -p tsconfig.test.json && tsc -p tsconfig.core-test.json && node --test tests/*.test.cjs",
    "typecheck": "tsc --noEmit",
    "lint": "expo lint",
    "verify": "npm test && npm run typecheck && npm run lint"
  },
  "dependencies": {
    "@expo-google-fonts/manrope": "^0.4.2",
    "@react-native-community/datetimepicker": "8.4.4",
    "expo": "~54.0.35",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.21",
    "expo-file-system": "~19.0.23",
    "expo-font": "~14.0.12",
    "expo-haptics": "~15.0.8",
    "expo-keep-awake": "~15.0.8",
    "expo-linking": "~8.0.12",
    "expo-navigation-bar": "~5.0.10",
    "expo-notifications": "~0.32.17",
    "expo-router": "~6.0.24",
    "expo-sharing": "~14.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "~0.21.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "typescript": "~5.9.2"
  }
}
